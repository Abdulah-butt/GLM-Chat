# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── GLM / Z.ai API (server-side only — never expose to the frontend) ────────
GLM_API_KEY=7ad9a872edb54ddfacab5017c3bbd66c.1pL9tiHzdu0Bm5O4
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-4.5-flash

# ─── Security ─────────────────────────────────────────────────────────────────
# Comma-separated allowlist. In production the frontend is same-origin, so this
# mainly matters for local dev (Vite on 5173) or external clients.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=10
BODY_LIMIT_JSON=100kb
